<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/editTextText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="60dp"
                android:hint="Digite ou fale..."
                android:inputType="text|textMultiLine"
                android:padding="12dp"
                android:background="@android:drawable/editbox_background"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/btnVoz"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:onClick="falarEntrada"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_btn_speak_now"
                android:scaleType="fitCenter"
                android:contentDescription="Falar" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="15dp"
            android:background="#E1E5EB"
            android:padding="5dp">

            <Spinner
                android:id="@+id/spinnerSource"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnInverter"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="10dp"
                android:onClick="inverterIdiomas"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Inverter" />

            <Spinner
                android:id="@+id/spinnerTarget"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1" />
        </LinearLayout>

        <Button
            android:id="@+id/button"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:onClick="traduzir"
            android:text="Traduzir"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4A90E2" />

        <TextView
            android:id="@+id/textViewTraducao"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            android:layout_weight="1"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:padding="15dp"
            android:textSize="20sp"
            android:textColor="#333333"
            android:gravity="center"
            android:hint="A tradução aparecerá aqui..." />

        <Button
            android:id="@+id/button2"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:onClick="falarTraducao"
            android:text="Ouvir Tradução"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4A90E2" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
